<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Hero image — always takes space; colorSurfaceVariant bg when no thumbnail -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="?attr/colorSurfaceVariant">

        <ImageView
            android:id="@+id/iv_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/iv_fallback"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_rss"
            android:alpha="0.18"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="16dp">

        <!-- Favicon · feed name · time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/iv_favicon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="5dp"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tv_feed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:alpha="0.6" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginStart="8dp"
                android:alpha="0.5" />
        </LinearLayout>

        <!-- Large title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="21sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.05"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="6dp" />

        <!-- Snippet -->
        <TextView
            android:id="@+id/tv_snippet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:alpha="0.65"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Heavier divider marks the end of the hero section -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.1" />

</LinearLayout>
