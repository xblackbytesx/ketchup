<?xml version="1.0" encoding="utf-8"?>
<!-- Half-width card — lives inside a 2-column GridLayoutManager -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_margin="4dp">

    <!-- Thumbnail block — always present; colorSurfaceVariant when no image -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="?attr/colorSurfaceVariant">

        <ImageView
            android:id="@+id/iv_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/iv_fallback"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_rss"
            android:alpha="0.18"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp">

        <!-- Favicon · feed name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="5dp">

            <ImageView
                android:id="@+id/iv_favicon"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="4dp"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tv_feed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:alpha="0.6" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:layout_marginStart="4dp"
                android:alpha="0.5" />
        </LinearLayout>

        <!-- Title — minLines=3 ensures both cards in a row are always equal height -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.1"
            android:minLines="3"
            android:maxLines="3"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Thin bottom border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.1" />

</LinearLayout>
