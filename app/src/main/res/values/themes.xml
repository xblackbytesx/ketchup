<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Minimal window theme for a Compose-only app.
        All real theming is handled in Compose via KetchupTheme.
        We extend android:Theme.Material.NoActionBar (available API 21+) to avoid
        any dependency on the View-based Material library.
    -->
    <style name="Theme.Ketchup" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorBackground">@color/ketchup_background_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
